map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80;
    server_name _;
    resolver 127.0.0.11 ipv6=off valid=30s;

    client_max_body_size ${CLIENT_MAX_BODY_SIZE};
    proxy_http_version 1.1;
    proxy_connect_timeout 30s;
    proxy_read_timeout ${PROXY_READ_TIMEOUT};
    proxy_send_timeout ${PROXY_READ_TIMEOUT};

    location = /healthz {
        add_header Content-Type text/plain;
        return 200 'ok';
    }

    location /xiaozhi/v1/ {
        set $ws_upstream http://xiaozhi-server:8000;
        proxy_pass $ws_upstream;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout ${WS_PROXY_READ_TIMEOUT};
        proxy_send_timeout ${WS_PROXY_READ_TIMEOUT};
        proxy_buffering off;
    }

    location /mcp/ {
        set $http_upstream http://xiaozhi-server:8003;
        proxy_pass $http_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        set $web_upstream http://xiaozhi-web:8002;
        proxy_pass $web_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
