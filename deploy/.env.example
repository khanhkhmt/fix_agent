# Common
TZ=Asia/Saigon
MYSQL_DATABASE=xiaozhi_esp32_server
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
REDIS_PASSWORD=

# Image tags
SERVER_IMAGE_NAME=xiaozhi-server-custom:local
WEB_IMAGE_NAME=xiaozhi-web-custom:local
MYSQL_IMAGE_TAG=latest
REDIS_IMAGE_TAG=8.0
EDGE_NGINX_TAG=1.27-alpine
NGINX_PROXY_TAG=1.7.0
ACME_COMPANION_TAG=2.6

# Production domain + Let's Encrypt
PUBLIC_DOMAIN=device.oriagent.com
LETSENCRYPT_EMAIL=gamo100@proton.me
HTTP_PORT=80
HTTPS_PORT=443

# Local / no-domain test
TEST_HTTP_BIND=127.0.0.1
TEST_HTTP_PORT=8080

# Reverse proxy behavior
CLIENT_MAX_BODY_SIZE=100m
PROXY_READ_TIMEOUT=300s
WS_PROXY_READ_TIMEOUT=3600s

# Resource limits
SERVER_CPU_LIMIT=1.2
SERVER_MEMORY_LIMIT=2500m
WEB_CPU_LIMIT=0.4
WEB_MEMORY_LIMIT=700m
MYSQL_CPU_LIMIT=0.2
MYSQL_MEMORY_LIMIT=400m
REDIS_CPU_LIMIT=0.1
REDIS_MEMORY_LIMIT=100m
EDGE_CPU_LIMIT=0.2
EDGE_MEMORY_LIMIT=128m
